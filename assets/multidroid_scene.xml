<mujoco>
    <option gravity="0 0 -1.62"/>
    <statistic extent="6" center="0 0 0"/>

    <default>
        <joint type="hinge" axis="0 1 0" damping="5.0"/>
        <geom friction="1.2 0.1 0.1" condim="6" solref="0.02 2"/>
    </default>

    <asset>
        <texture name="checker_tex" type="2d" builtin="checker" rgb1="0.3 0.3 0.3" rgb2="0.4 0.4 0.4" width="512" height="512"/>
        <material name="checker_pattern" texture="checker_tex" texrepeat="20 20" texuniform="true"/>

        <texture name="lunar_basic_tex" type="2d" file="lunar_surface.png"/>
        <material name="lunar_basic_mat" texture="lunar_basic_tex" texrepeat="0.1 0.1" texuniform="true"/>

        <texture name="lunar_terrain_tex" type="2d" file="moon_meteor_02_diff_2k.png"/>
        <material name="lunar_terrain_mat" texture="lunar_terrain_tex" texrepeat="1 1" texuniform="true"/>
        <hfield name="lunar_terrain_hfield" file="moon_meteor_02_disp_2k.png" size="20 20 0.5 0.1"/>

    </asset>

    <visual>
        <headlight ambient="0 0 0" diffuse="0 0 0" specular="0 0 0" />
        <global elevation="-20" azimuth="120" />
    </visual>

    <worldbody>
        <light name="sun_light" 
           directional="true" 
           pos="0 0 2"
           dir="1 1 -1" 
           diffuse="1.5 1.5 1.5" 
           ambient="0.0 0.0 0.0"
           specular="0.9 0.9 0.9" 
           castshadow="true" />

        <!-- <geom name="ground" type="plane" size="20 20 0.1" material="lunar_basic_mat"/> -->
        <geom name="ground" type="hfield" hfield="lunar_terrain_hfield" material="lunar_terrain_mat" pos="0 0 -0.2"/>

    </worldbody>

    <include file="skid_steer_rover.xml"/>

</mujoco>