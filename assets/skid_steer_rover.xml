<mujoco model="skid_steer_rover">
    <default>
        <joint type="hinge" axis="0 1 0" damping="5.0"/>
        <geom friction="1 0.005 0.0001"/>
    </default>

    <worldbody>

        <body name="player_rover" pos="0 0 0.5">
            <joint type="free" name="rover_root"/>
            
            <camera name="chase_cam" mode="fixed" pos="-3 0 1.5" xyaxes="0 -1 0 0.3 0 1"/>

            <geom name="chassis" type="box" size="0.5 0.25 0.1" rgba="0.2 0.6 0.2 1" mass="10"/>

            <body name="wheel_fl" pos="0.4 0.35 0">
                <joint name="joint_fl"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_fr" pos="0.4 -0.35 0">
                <joint name="joint_fr"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_ml" pos="0 0.35 0">
                <joint name="joint_ml"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_mr" pos="0 -0.35 0">
                <joint name="joint_mr"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_bl" pos="-0.4 0.35 0">
                <joint name="joint_bl"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_br" pos="-0.4 -0.35 0">
                <joint name="joint_br"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="motor_fl" joint="joint_fl" gear="1" ctrllimited="true" ctrlrange="-50 50"/>
        <motor name="motor_fr" joint="joint_fr" gear="1" ctrllimited="true" ctrlrange="-50 50"/>
        <motor name="motor_ml" joint="joint_ml" gear="1" ctrllimited="true" ctrlrange="-50 50"/>
        <motor name="motor_mr" joint="joint_mr" gear="1" ctrllimited="true" ctrlrange="-50 50"/>
        <motor name="motor_bl" joint="joint_bl" gear="1" ctrllimited="true" ctrlrange="-50 50"/>
        <motor name="motor_br" joint="joint_br" gear="1" ctrllimited="true" ctrlrange="-50 50"/>
    </actuator>

</mujoco>