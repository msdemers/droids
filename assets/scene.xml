<mujoco>
    <option gravity="0 0 -1.62"/>

    <default>
        <joint type="hinge" axis="0 1 0" damping="5.0"/>
        <geom friction="1 0.005 0.0001"/>
    </default>

    <asset>
        <texture name="checker_tex" type="2d" builtin="checker" rgb1="0.3 0.3 0.3" rgb2="0.4 0.4 0.4" width="512" height="512"/>
        <material name="checker_pattern" texture="checker_tex" texrepeat="20 20" texuniform="true"/>

        <texture name="lunar_tex" type="2d" file="lunar_surface.png"/>
        <material name="lunar_mat" texture="lunar_tex" texrepeat="0.1 0.1" texuniform="true"/>

        <texture name="moon_tex_diffuse" type="2d" file="moon_01_diff_4k.png"/>
        <texture name="moon_tex_normal" type="2d" file="moon_01_nor_gl_4k.png"/>
        <material name="moon_mat" texture="moon_tex_diffuse" 
                  specular="0.0" shininess="0.0" reflectance="0.0" 
                  texrepeat="5 5" texuniform="true"/>

    </asset>

    <worldbody>
        <light diffuse=".8 .8 .8" pos="0 0 5" dir="0 0 -1"/>

        <geom name="ground" type="plane" size="20 20 0.1" material="lunar_mat"/>

        <body name="player_rover" pos="0 0 0.5">
            <joint type="free" name="rover_root"/>
            
            <camera name="chase_cam" mode="fixed" pos="-3 0 1.5" xyaxes="0 -1 0 0.3 0 1"/>

            <geom name="chassis" type="box" size="0.5 0.25 0.1" rgba="0.2 0.6 0.2 1" mass="10"/>

            <body name="wheel_fl" pos="0.4 0.35 0">
                <joint name="joint_fl"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_fr" pos="0.4 -0.35 0">
                <joint name="joint_fr"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_ml" pos="0 0.35 0">
                <joint name="joint_ml"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_mr" pos="0 -0.35 0">
                <joint name="joint_mr"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_bl" pos="-0.4 0.35 0">
                <joint name="joint_bl"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>

            <body name="wheel_br" pos="-0.4 -0.35 0">
                <joint name="joint_br"/>
                <geom type="cylinder" size="0.15 0.05" rgba="0.1 0.1 0.1 1" euler="90 0 0"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="motor_fl" joint="joint_fl" gear="1" ctrllimited="true" ctrlrange="-30 30"/>
        <motor name="motor_fr" joint="joint_fr" gear="1" ctrllimited="true" ctrlrange="-30 30"/>
        <motor name="motor_ml" joint="joint_ml" gear="1" ctrllimited="true" ctrlrange="-30 30"/>
        <motor name="motor_mr" joint="joint_mr" gear="1" ctrllimited="true" ctrlrange="-30 30"/>
        <motor name="motor_bl" joint="joint_bl" gear="1" ctrllimited="true" ctrlrange="-30 30"/>
        <motor name="motor_br" joint="joint_br" gear="1" ctrllimited="true" ctrlrange="-30 30"/>
    </actuator>

</mujoco>